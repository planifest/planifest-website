# Planifest — Line ending rules
#
# Shell hook scripts MUST use LF endings to be executable by bash on all platforms.
# Git for Windows would otherwise write CRLF, which breaks the shebang line.
#
# Add this file to the root of any repo that uses planifest-framework/hooks/.

planifest-framework/hooks/pre-commit  text eol=lf
planifest-framework/hooks/pre-push    text eol=lf
